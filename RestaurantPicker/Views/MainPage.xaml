<Page
    x:Class="RestaurantPicker.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:RestaurantPicker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="20" ColumnSpacing="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="10">
            <TextBlock Text="Restaurant Entry" FontSize="24" FontWeight="SemiBold" />

            <TextBox Header="Name (required)" Text="{Binding CurrentRestaurant.Name, Mode=TwoWay}" />
            <TextBox Header="Restaurant Type (required)" Text="{Binding CurrentRestaurant.RestaurantType, Mode=TwoWay}" />
            <TextBox Header="Address" Text="{Binding CurrentRestaurant.Address, Mode=TwoWay}" />
            <TextBox Header="Website URL" Text="{Binding CurrentRestaurant.WebsiteUrl, Mode=TwoWay}" />

            <TextBlock Text="Google Maps API Key" FontSize="16" Margin="0,8,0,0" />
            <TextBox x:Name="GoogleMapsApiKeyTextBox" Header="API Key" PlaceholderText="AIza..." />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Save Map Key" Click="SaveMapApiKeyButton_Click" />
                <Button Content="Clear Map Key" Click="ClearMapApiKeyButton_Click" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Save" Command="{Binding SaveRestaurantCommand}" />
                <Button Content="Clear" Command="{Binding ClearFormCommand}" />
            </StackPanel>

            <TextBlock Text="Status" FontSize="16" Margin="0,8,0,0" />
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />

            <TextBlock Text="Selected Result" FontSize="16" Margin="0,12,0,0" />
            <TextBlock Text="{Binding SpinResult.Name}" FontSize="20" FontWeight="Bold" />
            <TextBlock Text="{Binding SpinResult.RestaurantType}" />
            <TextBlock Text="{Binding SpinResult.Address}" TextWrapping="Wrap" />
            <HyperlinkButton x:Name="ResultWebsiteLink" Content="Open website" Click="ResultWebsiteLink_Click" Visibility="Collapsed" />
        </StackPanel>

        <Grid Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid>
                <Canvas x:Name="WheelCanvas" Width="500" Height="500">
                    <Canvas.RenderTransform>
                        <RotateTransform x:Name="WheelRotateTransform" CenterX="250" CenterY="250" />
                    </Canvas.RenderTransform>
                </Canvas>

                <Polygon
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,-8,0,0"
                    Fill="#D32F2F"
                    Points="0,0 16,0 8,28" />
            </Grid>

            <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,-90" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <Button Content="Spin" Command="{Binding SpinWheelCommand}" />
                <Button Content="Map" Click="MapButton_Click" />
                <Button Content="Quit" Click="QuitButton_Click" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="0" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="6">
                <TextBlock Text="Restaurants" FontSize="24" FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding AvailableSets}"
                          SelectedItem="{Binding SelectedSet, Mode=TwoWay}"
                          DisplayMemberPath="Name"
                          Visibility="{Binding ShowSetSelector, Converter={StaticResource BooleanToVisibilityConverter}}"
                          HorizontalAlignment="Stretch" />
            </StackPanel>

            <ListView Grid.Row="1"
                      Margin="0,10,0,10"
                      VerticalAlignment="Stretch"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ItemsSource="{Binding Restaurants}"
                      SelectedItem="{Binding SelectedRestaurant, Mode=TwoWay}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="2" Padding="4">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding RestaurantType}" />
                            <TextBlock Text="{Binding Address}" TextWrapping="Wrap" />
                            <HyperlinkButton Content="Open website"
                                             Tag="{Binding WebsiteUrl}"
                                             Visibility="{Binding HasWebsite, Converter={StaticResource BooleanToVisibilityConverter}}"
                                             Click="RestaurantWebsiteLink_Click" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                <Button Content="Edit Selected" Command="{Binding EditSelectedRestaurantCommand}" />
                <Button Content="Delete Selected" Command="{Binding DeleteSelectedRestaurantCommand}" />
                <Button Content="Save Set" Click="SaveSetButton_Click" />
                <Button Content="Delete Set" Command="{Binding DeleteCurrentSetCommand}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="AppAuthorTextBlock" Foreground="#666666" />
            <TextBlock x:Name="AppVersionTextBlock" Grid.Column="1" Foreground="#666666" />
        </Grid>
    </Grid>
</Page>
